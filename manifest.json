{
    "manifest_version": 3,
    "name": "Пупупу",
    "version": "1.0",
    "description": "Расширение для взаимодействия с элементом main",
    "permissions": [
      "storage",
      "activeTab",
      "scripting"
    ],
    "host_permissions": [
      "https://example.com/*",
      "*://*/*"
    ],
    "action": {
      "default_popup": "popup.html",
      "default_title": "Управление функциями"
    },
    "background": {
      "service_worker": "background.js"
    },
    "content_scripts": [
      {
        "matches": ["<all_urls>"],
        "js": ["content.js"],
        "run_at": "document_end"
      }
    ]
  }